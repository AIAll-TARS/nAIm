    "contact": {
      "name": "nAIm Registry",
      "url": "https://naim.janis7ewski.org",
      "email": "aiall@janis7ewski.org"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "x-logo": {
      "url": "https://naim.janis7ewski.org/logo.png",
      "altText": "nAIm Logo"
    }
  },
