# nAIm monorepo environment template
# Copy values into backend/.env and frontend/.env.local as needed.

# --- Backend ---
DATABASE_URL=postgresql://naim:change_me@localhost:5432/naim
DB_PASSWORD=change_me
API_KEYS_RAW=replace_with_random_api_keys_comma_separated
RATING_PEPPER=replace_with_long_random_secret
ENVIRONMENT=development
LOG_LEVEL=INFO

# Public API base used by import scripts
NAIM_API_URL=https://api.naim.janis7ewski.org

# Required only for write/import scripts
NAIM_API_KEY=replace_with_write_api_key

# Optional integration
MOLTBOOK_API_KEY=replace_with_moltbook_key_if_needed

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:18792
NEXT_PUBLIC_SITE_URL=http://localhost:3000
